# URL of the Python backtest service (server-side only).
BACKTEST_URL=http://127.0.0.1:8000

# URL of the pm-agent service (server-side only).
PMAGENT_URL=http://127.0.0.1:8001

# Supabase persistence (optional). Leave blank to run without persistence —
# the app degrades gracefully and reports runs as "not persisted".
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
